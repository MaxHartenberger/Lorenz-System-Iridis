#!/bin/bash
# ============================================================================ #
# SLURM Job Array — Rerun specific (T, rec_id, N, m) cases
#
# Reads rerun_tasks.txt (generated by generate_rerun_tasks.jl from
# cases_to_rerun.csv).  Each array task runs ONE specific case via
# hpc_worker.jl (single-case worker).
#
# MaxArraySize = 1001, so submit in chunks:
#   sbatch --array=1-1000     submit_rerun.slurm
#   sbatch --array=1001-2000  submit_rerun.slurm
#   ... etc
# ============================================================================ #

# ---------------------------------------------------------------------------- #
# SLURM directives
# ---------------------------------------------------------------------------- #
#SBATCH --job-name=lorenz-rerun
#SBATCH --output=logs/rerun_slurm_%A_%a.out
#SBATCH --error=logs/rerun_slurm_%A_%a.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=3500                               # 3.5 GB (amd_student limit: 3.75 GB)
#SBATCH --time=12:00:00
#SBATCH --partition=amd_student

# ---------------------------------------------------------------------------- #
# Environment setup
# ---------------------------------------------------------------------------- #
module load julia/1.12.4
if [ $? -ne 0 ]; then
    echo "ERROR: Failed to load Julia module 'julia/1.12.4'."
    exit 2
fi

PROJECT_ROOT="$SLURM_SUBMIT_DIR"
cd "$PROJECT_ROOT" || exit 2
mkdir -p logs

# ---------------------------------------------------------------------------- #
# Read parameters for this array task
# ---------------------------------------------------------------------------- #
TASK_LIST="rerun_tasks.txt"

if [ ! -f "$TASK_LIST" ]; then
    echo "ERROR: $TASK_LIST not found."
    echo "       Run:  julia scripts/generate_rerun_tasks.jl"
    exit 2
fi

TOTAL_TASKS=$(wc -l < "$TASK_LIST")
if [ "$SLURM_ARRAY_TASK_ID" -gt "$TOTAL_TASKS" ]; then
    echo "WARNING: Array task ID $SLURM_ARRAY_TASK_ID > task list ($TOTAL_TASKS)."
    exit 0
fi

PARAMS=$(sed -n "${SLURM_ARRAY_TASK_ID}p" "$TASK_LIST")

# Parse: T rec_id N m
set -- $PARAMS
T="$1"
REC_ID="$2"
N="$3"
M="$4"

if [ -z "$T" ] || [ -z "$REC_ID" ] || [ -z "$N" ] || [ -z "$M" ]; then
    echo "ERROR: Failed to parse parameters from line $SLURM_ARRAY_TASK_ID"
    echo "       Raw: $PARAMS"
    exit 2
fi

echo "=============================================="
echo "SLURM Job ID:    ${SLURM_JOB_ID}"
echo "Array Task ID:   ${SLURM_ARRAY_TASK_ID} / ${TOTAL_TASKS}"
echo "Parameters:      T=${T}, rec_id=${REC_ID}, N=${N}, m=${M}"
echo "Started at:      $(date)"
echo "Node:            $(hostname)"
echo "=============================================="
echo ""

# Run single-case worker (sequential, no threading needed)
julia scripts/hpc_worker.jl "$T" "$REC_ID" "$N" "$M"

EXIT_CODE=$?
echo ""
echo "Finished at:     $(date)"
echo "Exit code:       ${EXIT_CODE}"
exit $EXIT_CODE
