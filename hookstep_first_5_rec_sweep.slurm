#!/bin/bash
# ============================================================================ #
# Hookstep (Newton–GMRES trust-region) sweep — first 5 recurrences per T.
#
# One (T, rec_id, N, gmres_maxiter) per task, 1 CPU.
# The task list is auto-generated by the first array task — just submit:
#
#   sbatch --array=1-630 hookstep_first_5_rec_sweep.slurm
#
# Sweep:  T ∈ {5,10,20,40,80,160}  ×  rec ∈ {1..5}  ×
#         N ∈ {5,10,20,40,80,160,320}  ×  gmres_maxiter ∈ {5,10,20}
#         6 × 5 × 7 × 3 = 630 tasks
# ============================================================================ #

#SBATCH --job-name=lorenz_hk
#SBATCH --output=logs/hookstep_%A_%a.out
#SBATCH --error=logs/hookstep_%A_%a.err
#SBATCH --nodes=1
#SBATCH --ntasks=1
#SBATCH --cpus-per-task=1
#SBATCH --mem=3700
#SBATCH --time=04:00:00
#SBATCH --partition=amd_student

module load julia/1.12.4 || { echo "ERROR: Julia module not found"; exit 2; }
cd "$SLURM_SUBMIT_DIR" || exit 2
mkdir -p logs

# --- Guard: must be submitted with --array ---
if [ -z "${SLURM_ARRAY_TASK_ID}" ]; then
    echo "ERROR: SLURM_ARRAY_TASK_ID is unset."
    echo "You submitted without --array.  Use:"
    echo "  sbatch --array=1-630 hookstep_first_5_rec_sweep.slurm"
    exit 2
fi

# --- Self-generating task list (only task 1 does it; atomic mkdir lock) ---
TASK_FILE="hookstep_tasks_${SLURM_ARRAY_JOB_ID}.txt"
LOCK_DIR="hookstep_tasks_${SLURM_ARRAY_JOB_ID}.lock"

if mkdir "$LOCK_DIR" 2>/dev/null; then
    > "$TASK_FILE"
    for T in 5 10 20 40 80 160; do
        for rec in $(seq 1 5); do
            for N in 5 10 20 40 80 160 320; do
                for gmres in 5 10 20; do
                    echo "$T $rec $N $gmres" >> "$TASK_FILE"
                done
            done
        done
    done
    echo "task ${SLURM_ARRAY_TASK_ID}: generated $TASK_FILE ($(wc -l < "$TASK_FILE") lines)"
    rmdir "$LOCK_DIR"
fi

# Wait for task file (60 s timeout)
for i in $(seq 1 60); do
    [ -f "$TASK_FILE" ] && break
    sleep 1
done
if [ ! -f "$TASK_FILE" ]; then
    echo "ERROR: $TASK_FILE not created within 60 s — aborting."
    exit 2
fi

# --- Run this task's case ---
PARAMS=$(sed -n "${SLURM_ARRAY_TASK_ID}p" "$TASK_FILE")

if [ -z "$PARAMS" ]; then
    echo "task ${SLURM_ARRAY_TASK_ID}  (empty — skipping)"
    exit 0
fi

set -- $PARAMS

echo "task ${SLURM_ARRAY_TASK_ID}  T=$1 rec=$2 N=$3 gmres_maxiter=$4  $(date)"

julia scripts/hpc_worker_hookstep.jl "$1" "$2" "$3" "$4"
exit $?
